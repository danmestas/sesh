{
  "mcpServers": {
    "nats": {
      "command": "bun",
      "args": [
        "run",
        "--cwd",
        "/opt/sesh-channels/claude-nats-channel",
        "--shell=bun",
        "--silent",
        "start"
      ],
      "env": {
        "CLAUDE_CWD": "/workspace",
        "CLAUDE_PLUGIN_ROOT": "/opt/sesh-channels/claude-nats-channel",
        "NATS_CHANNEL_STRICT": "1"
      }
    }
  }
}
