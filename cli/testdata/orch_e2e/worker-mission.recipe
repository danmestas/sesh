# worker-mission.recipe — fossil-worker stub recipe.
#
# The orch-variant e2e test (TestE2E_FullMissionLoop) drives stub-claude
# through this recipe inside a `sesh worktree alpha` checkout. Each line
# stands in for one step a real claude-worker would take when given the
# fossil-worker accessory.
#
# Output of running this recipe: mission.txt is added to the checkout
# and committed to the trunk. The test's verifier phase then reads
# `fossil timeline` and asserts the commit landed.
#
# `sesh up` registers the operator's $USER in the project repo's user
# table at seed time (sesh#77), so the recipe runs as the operator's
# natural $USER — no `fossil user new` priming needed.
echo "mission accomplished" > mission.txt
fossil add mission.txt
fossil commit -m "implement mission"
